# ─── LLM Provider Keys (add at least one) ───────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ─── Default Settings ────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=openai          # openai | anthropic | gemini
DEFAULT_LLM_MODEL=gpt-4o             # model name for chosen provider
DEFAULT_LANGUAGE=English             # English | Spanish | French | German | etc.

# ─── Carousel Settings ───────────────────────────────────────────────────────
CAROUSEL_WIDTH=1080
CAROUSEL_HEIGHT=1080
CAROUSEL_FONT_SIZE=52
